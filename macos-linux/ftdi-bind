#!/usr/bin/env bash
#
# ftdi-bind VID:PID [--dry-run]
#
# Re-attach the kernel ftdi_sio driver to every USB interface whose parent
# device matches VID:PID and that currently has NO driver ‚Äî e.g. after
# ftdi-unbind, or after libusb/pyftdi left it detached on exit.
#
# Safe by design:
#   * binds ONLY interfaces that are currently driverless
#   * never steals an interface from another driver
#   * skips interfaces already bound to ftdi_sio
#   * --dry-run shows exactly what it would do and changes nothing
#
set -euo pipefail
shopt -s nullglob

DRIVER=/sys/bus/usb/drivers/ftdi_sio
PROG=${0##*/}

usage() {
    cat >&2 <<EOF
usage: $PROG VID:PID [--dry-run]

  $PROG 0403:6015          re-attach ftdi_sio to all FT231X (0403:6015)
  $PROG 0x0403:0x6015 -n   preview only ‚Äî change nothing

Counterpart to ftdi-unbind. A device unplug/replug also rebinds.
EOF
    exit 2
}

DRYRUN=0
VIDPID=""
for a in "$@"; do
    case "$a" in
        -n|--dry-run) DRYRUN=1 ;;
        -h|--help)    usage ;;
        -*)           echo "$PROG: unknown option $a" >&2; usage ;;
        *)            VIDPID="$a" ;;
    esac
done
[ -n "$VIDPID" ] || usage

# Normalise VID:PID -> lowercase, strip any 0x, zero-pad to 4 hex digits.
arg="${VIDPID,,}"; arg="${arg//0x/}"
[[ "$arg" == *:* ]] || usage
vraw="${arg%%:*}"; praw="${arg##*:}"
[[ "$vraw" =~ ^[0-9a-f]{1,4}$ && "$praw" =~ ^[0-9a-f]{1,4}$ ]] || usage
VID=$(printf '%04x' "0x$vraw")
PID=$(printf '%04x' "0x$praw")

# Need root to write sysfs / modprobe ‚Äî but only if actually changing things.
if [ "$DRYRUN" -eq 0 ] && [ "$(id -u)" -ne 0 ]; then
    exec sudo "$(readlink -f "$0")" "$@"
fi

# Ensure ftdi_sio is loaded so the driver's bind file exists. (modprobe
# also auto-binds matching devices, which is fine ‚Äî the end state we want.)
if [ ! -d "$DRIVER" ]; then
    if [ "$DRYRUN" -eq 1 ]; then
        echo "$PROG: ftdi_sio not loaded (would 'modprobe ftdi_sio')"
    else
        modprobe ftdi_sio 2>/dev/null || {
            echo "$PROG: could not load ftdi_sio" >&2
            exit 1
        }
    fi
fi

matched=0
acted=0
for devdir in /sys/bus/usb/devices/*; do
    [ -r "$devdir/idVendor" ] || continue
    [ "$(< "$devdir/idVendor")" = "$VID" ] || continue
    [ "$(< "$devdir/idProduct")" = "$PID" ] || continue
    matched=1
    dev=${devdir##*/}
    serial=$(cat "$devdir/serial" 2>/dev/null || echo "no-serial")
    echo "device $dev  ($VID:$PID, serial: $serial)"
    for intf in /sys/bus/usb/devices/"$dev":*; do
        [ -d "$intf" ] || continue
        id=${intf##*/}
        if [ -d "$DRIVER" ] && [ -e "$DRIVER/$id" ]; then
            echo "  skip    $id (already bound to ftdi_sio)"
        elif [ -e "$intf/driver" ]; then
            other=$(basename "$(readlink -f "$intf/driver")")
            echo "  skip    $id (bound to $other ‚Äî not touching)"
        else
            if [ "$DRYRUN" -eq 1 ]; then
                echo "  would bind $id"
            elif echo -n "$id" > "$DRIVER/bind" 2>/dev/null; then
                echo "  bound   $id"
                acted=$((acted + 1))
            else
                echo "  WARN: failed to bind $id (does ftdi_sio support $VID:$PID?)" >&2
            fi
        fi
    done
done

if [ "$matched" -eq 0 ]; then
    echo "$PROG: no device matching $VID:$PID is attached." >&2
    exit 1
fi

if [ "$DRYRUN" -eq 1 ]; then
    echo "(dry run ‚Äî nothing changed)"
else
    echo "$PROG: $acted interface(s) bound."
fi
