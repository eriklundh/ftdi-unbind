#!/usr/bin/env bash
#
# ftdi-unbind  [--list] | [--dry-run] [--all] VID:PID
#
# Detach the FTDI kernel driver from a USB device matched by VID:PID,
# freeing it for WebUSB, libusb, or pyftdi.
#
#   Linux:  unbinds ftdi_sio per interface via sysfs.
#   macOS:  unloads AppleUSBFTDI / FTDIUSBSerialDriver kext(s).
#           kext unload is global — ALL attached FTDI devices are released.
#
# Flags:
#   --list      list all USB devices and their current driver (no VID:PID)
#   --dry-run   show what would happen; change nothing
#   --all       act even when multiple devices match VID:PID
#               (macOS: also required to confirm global kext unload affects
#                more than one matching device)
#   --about     print version and copyright
#   -h/--help   show this help
#
# Exit codes:  0 = OK   1 = no match / refused ambiguity   2 = bad args
#
set -euo pipefail

PROG=${0##*/}
OS="$(uname -s)"
[[ "$OS" == "Linux" ]] && shopt -s nullglob

VERSION="0.2.0"
ABOUT_TEXT="${PROG} ${VERSION}
(c) 2026 Erik Lundh — The Joy of Engineering, Compelcon AB
Platforms: Linux, macOS
Same flags and exit codes as ftdi-unbind.exe (Windows / libwdi)."

usage() {
    cat >&2 <<EOF
usage: $PROG [--list] | [--dry-run] [--all] VID:PID

  --list      list all USB devices and their current driver (no VID:PID needed)
  --dry-run   show which device(s) would be acted on; change nothing
  --all       act on all matching devices (overrides ambiguity guard)
              macOS: required when >1 FTDI device is attached to confirm
              that kext unload will release all of them simultaneously
  -h/--help   show this help
  --about     show version and copyright

  VID:PID  accepted forms: 0403:6015  0x0403:0x6015  403:6015

  Linux:  unbinds ftdi_sio per interface via sysfs (scoped to VID:PID)
  macOS:  unloads AppleUSBFTDI / FTDIUSBSerialDriver kext(s) — releases
          ALL attached FTDI devices, not just the one specified

Restore with:  ftdi-bind VID:PID   (or unplug/replug the device)
EOF
    exit 2
}

# ---------------------------------------------------------------------------
# Argument parsing (shared)
# ---------------------------------------------------------------------------
DRYRUN=0; ALL=0; LIST=0; VIDPID=""
for a in "$@"; do
    case "$a" in
        -n|--dry-run) DRYRUN=1 ;;
        --all)        ALL=1 ;;
        --list)       LIST=1 ;;
        --about)      echo "$ABOUT_TEXT"; exit 0 ;;
        -h|--help)    usage ;;
        -*)           echo "$PROG: unknown option '$a'" >&2; usage ;;
        *)            VIDPID="$a" ;;
    esac
done

# --list needs no VID:PID; everything else does.
if [ "$LIST" -eq 0 ] && [ -z "$VIDPID" ]; then
    usage
fi

# Normalise VID:PID — tr replaces bash 4 ${var,,} which isn't in macOS bash 3.2.
if [ -n "$VIDPID" ]; then
    arg=$(echo "$VIDPID" | tr '[:upper:]' '[:lower:]'); arg="${arg//0x/}"
    [[ "$arg" == *:* ]] || { echo "$PROG: invalid VID:PID '$VIDPID'" >&2; usage; }
    vraw="${arg%%:*}"; praw="${arg##*:}"
    [[ "$vraw" =~ ^[0-9a-f]{1,4}$ && "$praw" =~ ^[0-9a-f]{1,4}$ ]] || \
        { echo "$PROG: invalid VID:PID '$VIDPID'" >&2; usage; }
    VID=$(printf '%04x' "0x$vraw")
    PID=$(printf '%04x' "0x$praw")
fi

# Portable script path for sudo re-exec (readlink -f is GNU-only; not on macOS).
SCRIPT_PATH="$(cd "$(dirname "$0")"; pwd -P)/$(basename "$0")"

# ---------------------------------------------------------------------------
# OS dispatch
# ---------------------------------------------------------------------------
case "$OS" in

# ===========================================================================
Linux)
# ===========================================================================

# ---- --list ----------------------------------------------------------------
if [ "$LIST" -eq 1 ]; then
    printf "%-9s  %-40s  [driver]\n" "VID:PID" "description"
    printf '%0.s-' {1..68}; echo
    found=0
    for devdir in /sys/bus/usb/devices/*; do
        [ -r "$devdir/idVendor" ] || continue
        d_vid=$(< "$devdir/idVendor")
        d_pid=$(< "$devdir/idProduct")
        d_desc=$(tr -d '\n' < "$devdir/product" 2>/dev/null || echo "(unknown)")
        d_driver=""
        d_dev="${devdir##*/}"
        for intf in /sys/bus/usb/devices/"$d_dev":*; do
            [ -L "$intf/driver" ] || continue
            d_driver=$(basename "$(readlink "$intf/driver")")
            break
        done
        printf "%s:%s  %-40s  [%s]\n" \
            "$d_vid" "$d_pid" "${d_desc:0:40}" "${d_driver:-(none)}"
        found=1
    done
    [ "$found" -eq 1 ] || echo "(no USB devices found)"
    exit 0
fi

# ---- unbind ----------------------------------------------------------------
DRIVER=/sys/bus/usb/drivers/ftdi_sio

if [ "$DRYRUN" -eq 0 ] && [ "$(id -u)" -ne 0 ]; then
    exec sudo "$SCRIPT_PATH" "$@"
fi

if [ ! -d "$DRIVER" ]; then
    echo "$PROG: ftdi_sio not loaded — nothing is bound, nothing to do."
    exit 0
fi

# Collect all matching devices first so we can apply the ambiguity check.
matched_devs=()
for devdir in /sys/bus/usb/devices/*; do
    [ -r "$devdir/idVendor" ]               || continue
    [ "$(< "$devdir/idVendor")"  = "$VID" ] || continue
    [ "$(< "$devdir/idProduct")" = "$PID" ] || continue
    matched_devs+=("$devdir")
done

count="${#matched_devs[@]}"
if [ "$count" -eq 0 ]; then
    echo "$PROG: no device matching $VID:$PID is attached." >&2
    exit 1
fi
if [ "$count" -gt 1 ] && [ "$ALL" -eq 0 ]; then
    echo "$PROG: $count devices match $VID:$PID — use --all to act on all, or unplug the others." >&2
    for devdir in "${matched_devs[@]}"; do
        d_dev="${devdir##*/}"
        d_serial=$(cat "$devdir/serial" 2>/dev/null || echo "no-serial")
        echo "  $VID:$PID  bus-id: $d_dev  serial: $d_serial" >&2
    done
    exit 1
fi

acted=0
for devdir in "${matched_devs[@]}"; do
    dev="${devdir##*/}"
    serial=$(cat "$devdir/serial" 2>/dev/null || echo "no-serial")
    echo "device $dev  ($VID:$PID, serial: $serial)"
    for intf in /sys/bus/usb/devices/"$dev":*; do
        [ -d "$intf" ] || continue
        id="${intf##*/}"
        if [ -e "$DRIVER/$id" ]; then
            if [ "$DRYRUN" -eq 1 ]; then
                echo "  would unbind $id"
            elif echo -n "$id" > "$DRIVER/unbind" 2>/dev/null; then
                echo "  unbound  $id"
                acted=$((acted + 1))
            else
                echo "  WARN: failed to unbind $id" >&2
            fi
        else
            echo "  skip     $id (not bound to ftdi_sio)"
        fi
    done
done

if [ "$DRYRUN" -eq 1 ]; then
    echo "(dry run — nothing changed)"
else
    echo "$PROG: $acted interface(s) unbound."
fi

;;
# ===========================================================================
Darwin)
# ===========================================================================

APPLE_KEXT="com.apple.driver.AppleUSBFTDI"
FTDI_VCP_KEXT="com.FTDI.driver.FTDIUSBSerialDriver"
FTDI_VID_DEC=1027   # 0x0403

# Helper: query IOKit for all IOUSBDevice entries, print JSON-like lines.
# Requires python3 (pre-installed on macOS or via Xcode CLT stub).
macos_ioreg_devices() {
    # Args: vid_dec pid_dec (optional; omit both to list everything)
    python3 - "$@" <<'PYEOF'
import sys, subprocess, plistlib

filter_vid = int(sys.argv[1]) if len(sys.argv) > 1 else None
filter_pid = int(sys.argv[2]) if len(sys.argv) > 2 else None

try:
    raw = subprocess.check_output(
        ['ioreg', '-r', '-c', 'IOUSBDevice', '-a'],
        stderr=subprocess.DEVNULL)
    devices = plistlib.loads(raw)
except Exception as e:
    print(f"error: ioreg query failed: {e}", file=sys.stderr)
    sys.exit(2)

found = []
for d in devices:
    vid = d.get('idVendor',  0)
    pid = d.get('idProduct', 0)
    if filter_vid is not None and vid != filter_vid:
        continue
    if filter_pid is not None and pid != filter_pid:
        continue
    found.append(d)

# Output: first line is the count, then one device per line.
print(len(found))
for d in found:
    vid    = d.get('idVendor',  0)
    pid    = d.get('idProduct', 0)
    name   = (d.get('USB Product Name') or
              d.get('kUSBProductString') or '(unknown)')
    serial = d.get('USB Serial Number') or 'no-serial'
    print(f"{vid:04x}:{pid:04x}\t{name}\t{serial}")
sys.exit(0 if found else 1)
PYEOF
}

# ---- --list ----------------------------------------------------------------
if [ "$LIST" -eq 1 ]; then
    apple_loaded=0; ftdi_loaded=0
    kextstat 2>/dev/null | grep -qF "$APPLE_KEXT"    && apple_loaded=1
    kextstat 2>/dev/null | grep -qF "$FTDI_VCP_KEXT" && ftdi_loaded=1

    python3 - "$apple_loaded" "$ftdi_loaded" "$FTDI_VID_DEC" <<'PYEOF'
import sys, subprocess, plistlib

apple_loaded = sys.argv[1] == "1"
ftdi_loaded  = sys.argv[2] == "1"
ftdi_vid     = int(sys.argv[3])

try:
    raw = subprocess.check_output(
        ['ioreg', '-r', '-c', 'IOUSBDevice', '-a'],
        stderr=subprocess.DEVNULL)
    devices = plistlib.loads(raw)
except Exception as e:
    print(f"error: ioreg query failed: {e}", file=sys.stderr)
    sys.exit(1)

print(f"{'VID:PID':<9}  {'description':<40}  [driver]")
print("-" * 68)
if not devices:
    print("(no USB devices found)")
    sys.exit(0)
for d in devices:
    vid  = d.get('idVendor',  0)
    pid  = d.get('idProduct', 0)
    name = (d.get('USB Product Name') or
            d.get('kUSBProductString') or '(unknown)')
    if vid == ftdi_vid:
        if ftdi_loaded:
            driver = "FTDIUSBSerialDriver"
        elif apple_loaded:
            driver = "AppleUSBFTDI"
        else:
            driver = "(none)"
    else:
        driver = "(system)"
    print(f"{vid:04x}:{pid:04x}  {name[:40]:<40}  [{driver}]")
PYEOF
    exit 0
fi

# ---- unbind ----------------------------------------------------------------
VID_DEC=$(( 16#$VID ))
PID_DEC=$(( 16#$PID ))

# Verify device is present and get match count.
echo "Looking for device $VID:$PID..."
ioreg_out=$(macos_ioreg_devices "$VID_DEC" "$PID_DEC") || {
    echo "$PROG: no device matching $VID:$PID is attached." >&2
    exit 1
}
device_count=$(echo "$ioreg_out" | head -1)
echo "Found $device_count device(s):"
echo "$ioreg_out" | tail -n +2 | while IFS=$'\t' read -r vpid name serial; do
    echo "  $name  ($vpid, serial: $serial)"
done

# Find loaded FTDI kexts.
loaded_kexts=()
for kext in "$APPLE_KEXT" "$FTDI_VCP_KEXT"; do
    kextstat 2>/dev/null | grep -qF "$kext" && loaded_kexts+=("$kext")
done

if [ "${#loaded_kexts[@]}" -eq 0 ]; then
    echo ""
    echo "$PROG: no FTDI kext is loaded — device may already be free for WebUSB."
    exit 0
fi

# Ambiguity guard: kext unload is global, so warn when >1 matching device.
if [ "$device_count" -gt 1 ] && [ "$ALL" -eq 0 ]; then
    echo "" >&2
    echo "$PROG: $device_count devices match $VID:$PID." >&2
    echo "  kext unload is global — ALL attached FTDI devices will be released." >&2
    echo "  Use --all to confirm." >&2
    exit 1
fi

echo ""
echo "Kext(s) to unload (releases ALL attached FTDI devices):"
for kext in "${loaded_kexts[@]}"; do
    echo "  $kext"
done

if [ "$DRYRUN" -eq 1 ]; then
    echo ""
    echo "(dry run — nothing changed)"
    exit 0
fi

if [ "$(id -u)" -ne 0 ]; then
    exec sudo "$SCRIPT_PATH" "$@"
fi

acted=0
for kext in "${loaded_kexts[@]}"; do
    echo "Unloading $kext ..."
    err_file=$(mktemp /tmp/ftdi-kextunload-XXXXXX)
    if kextunload -b "$kext" 2>"$err_file"; then
        echo "  unloaded."
        acted=$((acted + 1))
    else
        err=$(<"$err_file")
        echo "  WARN: could not unload $kext" >&2
        [ -n "$err" ] && echo "  $err" >&2
        macos_ver=$(sw_vers -productVersion 2>/dev/null || echo "unknown")
        if echo "$err" | grep -qiE "operation not permitted|can.t unload|not found"; then
            cat >&2 <<HINT

  On macOS $macos_ver the system kext '$kext' is protected by SIP
  and cannot be unloaded at runtime without reducing security.

  Practical alternatives:
    1. Switch to the Web Serial backend in the terminal app — works
       with the FTDI VCP driver in place; no driver swap required.
    2. Boot into Recovery OS → Startup Security Utility →
       set 'Reduced Security', reboot, then retry.
    3. If FTDI's own VCP kext is installed separately:
         sudo kextunload -b $FTDI_VCP_KEXT

HINT
        fi
    fi
    rm -f "$err_file"
done

echo ""
echo "$PROG: $acted kext(s) unloaded."
[ "$acted" -gt 0 ] || exit 1

;;
# ===========================================================================
*)
# ===========================================================================
echo "$PROG: unsupported OS '$OS' — Linux and macOS are supported." >&2
exit 1
;;

esac
