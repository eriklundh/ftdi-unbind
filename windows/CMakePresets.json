{
  "version": 3,
  "configurePresets": [
    {
      "name": "vs2022-x64-release",
      "displayName": "VS 2022 x64 Release",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LIBWDI_INCLUDE_DIR": "C:/usr/local/src/libwdi/libwdi",
        "LIBWDI_LIB": "C:/usr/local/src/libwdi/x64/Release/lib/libwdi.lib"
      }
    },
    {
      "name": "vs2022-x64-tests",
      "displayName": "VS 2022 x64 Release + tests (probe + unit/CLI tests)",
      "inherits": "vs2022-x64-release",
      "cacheVariables": {
        "FTDI_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-x64-release",
      "configurePreset": "vs2022-x64-release",
      "configuration": "Release"
    },
    {
      "name": "vs2022-x64-tests",
      "configurePreset": "vs2022-x64-tests",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "vs2022-x64-tests",
      "configurePreset": "vs2022-x64-tests",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
